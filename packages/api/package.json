{
  "name": "@timecell/api",
  "version": "0.1.0",
  "type": "module",
  "description": "TimeCell API server",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc"
  },
  "dependencies": {
    "@timecell/engine": "*",
    "fastify": "^5",
    "@fastify/cors": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest"
  }
}
