{
  "name": "@timecell/api",
  "version": "0.1.1",
  "type": "module",
  "description": "TimeCell API server",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp -r ../web/dist dist/web 2>/dev/null || true"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/static": "^9.0.0",
    "@timecell/engine": "*",
    "fastify": "^5"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest"
  }
}
