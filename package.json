{
  "name": "timecell",
  "version": "0.1.0",
  "private": true,
  "description": "Know if you survive the crash before it happens",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/api & npm run dev --workspace=packages/web",
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "keywords": [
    "bitcoin",
    "portfolio",
    "crash-survival",
    "family-office"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
