{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(python3 scripts/engine-bridge.py*)",
      "Bash(cd packages/engine && npm test*)",
      "Bash(node -e*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreCompact": [
      {
        "command": ".claude/hooks/pre-compact.sh",
        "timeout": 5000
      }
    ]
  }
}
